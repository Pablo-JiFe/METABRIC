

# 9.1 Dividir en tiempo con base a mediana 

# Obtiene la mediana

median_disease.brca <- median(metadata_diseased.brca$OS_MONTHS)

# Genera una columna booleana donde los TRUE son aquellos que muerieron de manera temprana

metadata_diseased.brca <- metadata_diseased.brca %>% 
  mutate(BOOLEAN_TEMP = ifelse(OS_MONTHS <= median_disease.brca,
                               yes = "Early",
                               no = "Late"))





