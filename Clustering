library(tidyverse)
library(ConsensusClusterPlus)

# 1.- Obtención de datos --------------------------------------------------

# 1.1 Tabla de datos obtenidos de cBioconductor 

metabric_rna <- read.table("D:/brca_metabric/brca_metabric/data_mrna_illumina_microarray.txt",
                           header = TRUE)
# 1.2 Metadatos

metabric_clinicaldata <- read.delim(
  "D:/brca_metabric/brca_metabric/data_clinical_patient.txt",
  comment.char = "#",
  stringsAsFactors = FALSE
)

# 1.2.2 Los IDs estan con un guión mientras que en los datos originales estan con . asi que hago el cambio

metabric_clinicaldata$PATIENT_ID <- gsub("-", ".", metabric_clinicaldata$PATIENT_ID)


# 2.- Eliminar duplicados y columnas con caracteres -----------------------

# > metabric_rna[1:5,1:5]
#    Hugo_Symbol Entrez_Gene_Id  MB.0362  MB.0346   MB.0386
# 1        RERE            473 8.676978 9.653589  9.033589
# 2      RNF165         494470 6.075331 6.687887  5.910885
# 3        PHF7          51533 5.838270 5.600876  6.030718
# 4       CIDEA           1149 6.397503 5.246319 10.111816
# 5       TENT2         167153 7.906217 8.267256  7.959291

# 2.1 Intente hacerle median absolute deviation pero me dio error de que hay datos no numericos los cuales son los codigo hugo, adicionalmente no queremos que los numeros
# de Entrez se tomen como datos

# mad_metabric <- apply(metabric_rna, 1, mad)

# 2.1.2 Le intento asignar como rownames los nombres de entrez para posteriormente eliminar las columnas de nombres hugo y entrez

# rownames(metabric_rna) <- metabric_rna$Entrez_Gene_Id

# Error en `.rowNamesDF<-`(x, value = value):  no se permiten 'row.names' duplicados

# 2.1.3 Esto implica que hay ids de Entrez duplicados por lo que quiero eliminar los duplicados manteniendome unicamente con
# los de mas alta varianza

# 2.2 Entonces hago un nuevo objeto que no incluye las 2 primeras columnas (hugo y entrez)

expr_temp <- metabric_rna[, -(1:2)]

# 2.3 Se hace la varianza a todos

gene_var <- apply(expr_temp, 1, var)

# 2.4 Se asigna a nueva columna

metabric_rna$variance <- gene_var

# 2.5 Unicamente mantener los genes con mayor varianza

metabric_unique <- metabric_rna %>% # Datos iniciales
  group_by(Entrez_Gene_Id) %>% # Agrupar por nombre de Entrez (es decir agrupar repetidos)
  slice_max(order_by = variance, n = 1) %>% # Ordenar por varianza y quedarse con los mas altos de cada grupo
  ungroup()


# 2.5.2 Convertir de tibble a Data frame

metabric_unique <- as.data.frame(metabric_unique)

# 2.6 Ahora si asigno los nombres de entrez como rownames

rownames(metabric_unique) <- metabric_unique$Entrez_Gene_Id

# 2.6.2 Elimino las columnas con los nombres hugo y entrez para que no influyan en los calculos

metabric_unique$Hugo_Symbol <- NULL
metabric_unique$Entrez_Gene_Id <- NULL


# 3.- Preparar para clustering --------------------------------------------


# 3.1 Realizo ahora si la median absolute deviation

mad_metabric <- apply(metabric_unique, 1, mad)

# 3.2 Solo me quedo con los primeros 100 samples y genes, para eso primero ordena con base al mad

metabric_unique <- metabric_unique[rev(order(mad_metabric))[1:100], ]

metabric_unique <- metabric_unique[,1:100]


# 3.2.2 Convierte a matriz (porque si no no me lo acepta consnesusclusterplus)

metabric_matrix <- as.matrix(metabric_unique)

# 3.3 Clustering

results <- ConsensusClusterPlus(
  metabric_matrix, # Objetoa procesar, debe ser una matriz
  maxK = 10, # Numero maximo de clusters
  reps = 100, # Cuantas veces se repetira la funcipon
  pItem = 0.8, # Cuantos items
  pFeature = 1, # Cuantos features 
  title = "Prueba/", # A donde se van a guardar las imagenes
  clusterAlg = "hc", # Cluster jerarquico
  distance = "pearson",
  seed = 1262118388.71279,
  plot = "png" # Me da varias imagenes iniciales como heatmaps, cumulative distribution functions
)


# 4.- Observar resultados iniciales ---------------------------------------

# 4.1 Observar objeto

results

# 4.2 El consensus matrix del grupo 2. Consensus matrix es una medida de que tan común es que se 
# agrupen juntos yendo de 0 siendo poco a 1 siendo mucho

results[[2]][["consensusMatrix"]][1:10, 1:10]


